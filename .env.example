POSTGRES_DB=tailbook
POSTGRES_USER=tailbook
POSTGRES_PASSWORD=tailbook-change-me
POSTGRES_PORT=5432
REDIS_PASSWORD=tailbook-change-me
REDIS_PORT=6379
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=secret

# RabbitMQ — set to true to enable dedicated message broker for async workloads
# RabbitMq__Enabled=true
# RabbitMq__Host=localhost
# RabbitMq__Port=5672
# RabbitMq__Username=guest
# RabbitMq__Password=guest
# RabbitMq__Exchange=tailbook.events
INTEGRATION_OUTBOX_POLL_INTERVAL_SECONDS=15

TAILBOOK_API_PORT=5001
TAILBOOK_ADMIN_WEB_PORT=3001
TAILBOOK_CLIENT_WEB_PORT=3002
TAILBOOK_GROOMER_WEB_PORT=3003
API_ALLOWED_HOSTS=localhost;127.0.0.1

ConnectionStrings__Main=Host=localhost;Port=5432;Database=tailbook;Username=tailbook;Password=tailbook-change-me;Include Error Detail=true
ConnectionStrings__Redis=localhost:6379,password=tailbook-change-me,abortConnect=false,connectTimeout=500,syncTimeout=500
Jwt__Issuer=tailbook.local
Jwt__Audience=tailbook.apps
Jwt__SigningKey=change-this-in-production-and-make-it-long-random-secret
SensitivePayloadProtection__Key=change-this-in-production-and-make-it-long-random-sensitive-payload-secret
# SensitivePayloadProtection__PreviousKey is used during key rotation.
# Set this to the previous key value when rotating SensitivePayloadProtection__Key.
# Pending integration outbox messages protected with the old key can still be unprotected and delivered.
# After all old-key messages are processed, remove PreviousKey from the configuration.
# SensitivePayloadProtection__PreviousKey=previous-key-value-at-least-32-chars
BOOTSTRAP_ADMIN_EMAIL=admin@tailbook.local
BOOTSTRAP_ADMIN_PASSWORD=ChangeMeNow123!
BOOTSTRAP_ADMIN_DISPLAY_NAME=Bootstrap Administrator
PASSWORD_RESET_URL_BASE=http://localhost:3002/reset-password
SALON_TIMEZONE_ID=Europe/Kyiv
NOTIFICATIONS_PROVIDER=LocalFile
NOTIFICATIONS_LOCAL_FILE_PATH=./data/notifications/notifications.log
NOTIFICATIONS_MAX_DELIVERY_ATTEMPTS=5
NOTIFICATIONS_RETRY_BASE_DELAY_SECONDS=60
NOTIFICATIONS_RETRY_MAX_DELAY_SECONDS=3600
NOTIFICATIONS_SMTP_HOST=smtp.example.com
NOTIFICATIONS_SMTP_PORT=587
NOTIFICATIONS_SMTP_ENABLE_SSL=true
NOTIFICATIONS_SMTP_FROM_EMAIL=no-reply@example.com
NOTIFICATIONS_SMTP_FROM_NAME=Tailbook
NOTIFICATIONS_SMTP_USERNAME=
NOTIFICATIONS_SMTP_PASSWORD=
NOTIFICATIONS_SMTP_TIMEOUT_SECONDS=30
NEXT_PUBLIC_API_BASE_URL=https://localhost:5001
INTERNAL_API_BASE_URL=https://localhost:5001

# Landing page configuration — override to customise salon info without code changes
# NEXT_PUBLIC_SALON_NAME=Doggy Groom
# NEXT_PUBLIC_SALON_PHONE=+380 67 614 16 70
# NEXT_PUBLIC_SALON_PHONE_HREF=tel:+380676141670
# NEXT_PUBLIC_SALON_ADDRESS=бульвар Шевченка 10а, Запоріжжя
# NEXT_PUBLIC_SALON_INSTAGRAM=@doggy_groom
# NEXT_PUBLIC_SALON_INSTAGRAM_HREF=https://instagram.com/doggy_groom
ADMIN_APP_ORIGIN=http://localhost:3001
CLIENT_APP_ORIGIN=http://localhost:3002
GROOMER_APP_ORIGIN=http://localhost:3003

# Browser session transport: BodyTokens or RefreshCookie
# BodyTokens keeps refresh tokens in JSON request/response bodies (legacy).
# RefreshCookie sets HTTP-only cookies and uses double-submit CSRF.
# Local development uses BodyTokens (or RefreshCookie with CookieSecure=false).
# Production must use RefreshCookie with CookieSecure=true and HTTPS.
BrowserSessions__TokenTransport=BodyTokens
BrowserSessions__AllowLegacyBodyTokens=true
BrowserSessions__CookieSecure=false
AppCors__AllowCredentials=true

# Telemetry / observability
# Uncomment to route API telemetry to the local OTel Collector:
# Telemetry__OtlpEndpoint=http://localhost:4317
# Telemetry__ExportLogs=true
# In Docker Compose, the API uses http://otel-collector:4317 by default.
# For production, set OTEL_COLLECTOR_EXPORTER_ENDPOINT to forward telemetry upstream.
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=tailbook-local
# TLS_DOMAIN is the base domain for all services.
# For local testing without DNS, use tailbook.test (resolves to 127.0.0.1).
# Add to hosts file: 127.0.0.1 api.tailbook.test admin.tailbook.test client.tailbook.test groomer.tailbook.test
# TLS_MODE: "internal" for local self-signed dev certs, or "tls {email}" for Let's Encrypt production certs
TLS_DOMAIN=tailbook.test
TLS_MODE=internal
CADDY_EMAIL=admin@tailbook.test
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
