{
    "name": "tailbook",
    "private": true,
    "packageManager": "pnpm@10.33.0",
    "scripts": {
        "build": "turbo run build",
        "dev": "turbo run dev --parallel",
        "dev:api": "dotnet watch --project backend/src/Tailbook.Api.Host/Tailbook.Api.Host.csproj run",
        "dev:admin": "pnpm --filter admin-web dev",
        "dev:client": "pnpm --filter client-web dev",
        "dev:groomer": "pnpm --filter groomer-web dev",
        "lint": "turbo run lint",
        "prepare": "husky",
        "test": "turbo run test",
        "test:e2e": "playwright test",
        "test:e2e:ui": "playwright test --ui",
        "test:e2e:admin": "playwright test --project=admin-web",
        "test:e2e:client": "playwright test --project=client-web",
        "test:e2e:groomer": "playwright test --project=groomer-web",
        "test:e2e:install": "playwright install --with-deps chromium",
        "typecheck": "turbo run typecheck"
    },
    "lint-staged": {
        "apps/admin-web/**/*.{ts,tsx,js,mjs}": "eslint --config apps/admin-web/eslint.config.mjs --fix",
        "apps/client-web/**/*.{ts,tsx,js,mjs}": "eslint --config apps/client-web/eslint.config.mjs --fix",
        "apps/groomer-web/**/*.{ts,tsx,js,mjs}": "eslint --config apps/groomer-web/eslint.config.mjs --fix"
    },
    "devDependencies": {
        "@commitlint/cli": "^21.0.1",
        "@commitlint/config-conventional": "^21.0.1",
        "@playwright/test": "^1.60.0",
        "eslint": "^9.39.4",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.5",
        "turbo": "^2.9.9"
    }
}
