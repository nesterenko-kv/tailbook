{
  "ConnectionStrings": {
    "Main": "Host=localhost;Port=5432;Database=tailbook;Username=tailbook;Password=tailbook;Include Error Detail=true"
  },
  "Jwt": {
    "Issuer": "tailbook.local",
    "Audience": "tailbook.apps",
    "SigningKey": "change-this-in-local-dev-at-least-32-chars-long",
    "ExpirationMinutes": 120
  },
  "BootstrapAdmin": {
    "Email": "admin@tailbook.local",
    "Password": "MyV3ryC00lAdminP@ss",
    "DisplayName": "Bootstrap Administrator"
  },
  "LoginThrottling": {
    "MaxFailedAttempts": 5,
    "FailureWindowMinutes": 15,
    "LockoutMinutes": 15
  },
  "RefreshTokens": {
    "ExpirationDays": 30,
    "TokenBytes": 32
  },
  "MfaChallenge": {
    "ExpirationMinutes": 10,
    "CodeLength": 6,
    "MaxFailedAttempts": 5
  },
  "PasswordReset": {
    "ExpirationMinutes": 30,
    "TokenBytes": 32,
    "ResetUrlBase": "http://localhost:3002/reset-password"
  },
  "SensitivePayloadProtection": {
    "Key": "change-this-in-local-dev-sensitive-payload-key"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Formatting.Compact"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ]
  },
  "AllowedHosts": "*",
  "StaffScheduling": {
    "TimeZoneId": "Europe/Kyiv"
  },
  "Notifications": {
    "EnableBackgroundProcessing": false,
    "Provider": "LocalFile",
    "LocalFilePath": "./data/notifications/dev-notifications.log",
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpEnableSsl": true,
    "SmtpFromEmail": "no-reply@tailbook.local",
    "SmtpFromName": "Tailbook",
    "SmtpUsername": "",
    "SmtpPassword": "",
    "SmtpTimeoutSeconds": 30,
    "BackgroundPollIntervalSeconds": 15,
    "MaxDeliveryAttempts": 5,
    "RetryBaseDelaySeconds": 60,
    "RetryMaxDelaySeconds": 3600
  },
  "Audit": {
    "QueueCapacity": 10000,
    "BatchSize": 100,
    "FlushIntervalMilliseconds": 1000,
    "MaxWriteRetries": 3,
    "RetryDelayMilliseconds": 100
  },
  "AppCors": {
    "AllowedOrigins": [
      "http://localhost:3001",
      "http://localhost:3002",
      "http://localhost:3003"
    ],
    "AllowCredentials": true
  },
  "HttpTransport": {
    "EnforceHttpsRedirection": true,
    "UseHsts": true
  },
  "Telemetry": {
    "Enabled": true,
    "ServiceName": "tailbook-api",
    "DatabasePoolName": "tailbook-main",
    "ExportLogs": true,
    "OtlpEndpoint": ""
  }
}
