{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning"
    }
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "AppCors": {
    "AllowedOrigins": [
      "http://localhost:3001",
      "http://localhost:3002",
      "http://localhost:3003"
    ]
  },
  "HttpTransport": {
    "EnforceHttpsRedirection": false,
    "UseHsts": false
  },
  "Notifications": {
    "EnableBackgroundProcessing": true,
    "BackgroundPollIntervalSeconds": 15,
    "LocalFilePath": "./data/notifications/notifications.log"
  },
  "StaffScheduling": {
    "TimeZoneId": "Europe/Kyiv"
  }
}
