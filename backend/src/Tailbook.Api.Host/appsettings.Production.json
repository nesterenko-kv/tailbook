{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "AllowedHosts": "localhost;127.0.0.1",
  "AppCors": {
    "AllowedOrigins": [
      "http://localhost:3001",
      "http://localhost:3002",
      "http://localhost:3003"
    ],
    "AllowCredentials": true
  },
  "HttpTransport": {
    "EnforceHttpsRedirection": false,
    "UseHsts": false
  },
  "Notifications": {
    "EnableBackgroundProcessing": true,
    "Provider": "LocalFile",
    "BackgroundPollIntervalSeconds": 15,
    "MaxDeliveryAttempts": 5,
    "RetryBaseDelaySeconds": 60,
    "RetryMaxDelaySeconds": 3600,
    "LocalFilePath": "./data/notifications/notifications.log",
    "SmtpHost": "",
    "SmtpPort": 587,
    "SmtpEnableSsl": true,
    "SmtpFromEmail": "no-reply@tailbook.local",
    "SmtpFromName": "Tailbook",
    "SmtpUsername": "",
    "SmtpPassword": "",
    "SmtpTimeoutSeconds": 30
  },
  "StaffScheduling": {
    "TimeZoneId": "Europe/Kyiv"
  }
}
