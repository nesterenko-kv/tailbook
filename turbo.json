{
    "$schema": "https://turborepo.com/schema.json",
    "tasks": {
        "build": {
            "dependsOn": [
                "^build",
                "typecheck"
            ],
            "outputs": [
                ".next/**",
                "dist/**"
            ]
        },
        "dev": {
            "cache": false,
            "persistent": true
        },
        "lint": {
            "dependsOn": [
                "^lint"
            ]
        },
        "test": {
            "dependsOn": [
                "^test"
            ],
            "outputs": [
                "coverage/**",
                "test-results/**"
            ]
        },
        "typecheck": {
            "dependsOn": [
                "^typecheck"
            ]
        }
    }
}
